          <name>PRM_MPU</name>
          <description>Power Reset Module - MPU</description>
          <baseAddress>0x44E00E00</baseAddress>
          <groupName>Power Reset Modules</groupName>
          <registers>
            <register>
              <name>MPU_PWRSTCTRL</name>
              <addressOffset>0x00</addressOffset>
              <description>MPU_PWRSTCTRL Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>PowerState</name>
                  <description>bit: 0,1 (RW) Power state control [see e_PWR_STATE_CTRL]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>LogicRETState</name>
                  <description>bit: 2 (RW) Logic state when power domain is RETENTION [0x0 = logic_off; 0x1 = logic_ret]</description>
                  <bitOffset>2</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>LowPowerStateChange</name>
                  <description>bit: 4 (RW) Power state change request when domain has already performed a sleep transition [0x0 = Do not request; 0x1 = Request a low power state change]</description>
                  <bitOffset>3</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>MPU_RAM_ONState</name>
                  <description>bit: 16,17 (RW) Default power domain memory state when domain is ON [see e_PWR_CTRL_MEM_STATE]</description>
                  <bitOffset>4</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>MPU_L1_ONState</name>
                  <description>bit: 18,19 (R) Default power domain memory state when domain is ON.</description>
                  <bitOffset>6</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>MPU_L2_ONState</name>
                  <description>bit: 20,21 (R) Default power domain memory state when domain is ON.</description>
                  <bitOffset>8</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>mpu_l1_RETState</name>
                  <description>bit: 22 Reserved</description>
                  <bitOffset>10</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-only</access>
                </field>
                <field>
                  <name>mpu_l2_RETState</name>
                  <description>bit: 23 (RW) Default power domain memory(L1) retention state when power domain is in retention</description>
                  <bitOffset>11</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>mpu_ram_RETState</name>
                  <description>bit: 24 (RW) Default power domain memory(L2) retention state when power domain is in retention</description>
                  <bitOffset>12</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>MPU_PWRSTST</name>
              <addressOffset>0x04</addressOffset>
              <description>MPU_PWRSTST Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>PowerStateSt</name>
                  <description>bit: 0,1 (R) Current Power State Status [see e_PWR_STATE_STS]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>LogicStateSt</name>
                  <description>bit: 2 (R) Logic state status [0x0 = logic_off; 0x1 = logic_on]</description>
                  <bitOffset>2</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>MPU_RAM_StateSt</name>
                  <description>bit: 5,4 (R) MPU_RAM memory state status [see e_PWR_STATE_MEM_STS]</description>
                  <bitOffset>3</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>MPU_L1_StateSt</name>
                  <description>bit: 6,7 (R) MPU L1 memory state status [see e_PWR_STATE_MEM_STS]</description>
                  <bitOffset>5</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>MPU_L2_StateSt</name>
                  <description>bit: 8,9 (R) MPU L2 memory state status [see e_PWR_STATE_MEM_STS]</description>
                  <bitOffset>7</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>InTransition</name>
                  <description>bit: 20 (R) Domain transition status [0x0 = No on-going transition; 0x1 = transition is in progress.]</description>
                  <bitOffset>9</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>MPU_RSTST</name>
              <addressOffset>0x08</addressOffset>
              <description>MPU_RSTST Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>EMULATION_MPU_RST</name>
                  <description>bit: 5 (RW) MPU Processor has been reset due to emulation reset source e.g. assert reset command initiated by the icepick module [0x0 = RESET_NO; 0x1 = RESET_YES]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ICECRUSHER_MPU_RST</name>
                  <description>bit: 6 (RW) MPU Processor has been reset due to MPU ICECRUSHER1 resetevent [0x0 = RESET_NO; 0x1 = RESET_YES]</description>
                  <bitOffset>1</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
          </registers>
        </peripheral>
        <peripheral>
          <name>PRM_PER</name>
          <description>Power Reset Module - Peripheral</description>
          <baseAddress>0x44E00C00</baseAddress>
          <groupName>Power Reset Modules</groupName>
          <registers>
            <register>
              <name>PER_RSTCTRL</name>
              <addressOffset>0x00</addressOffset>
              <description>PER_RSTCTRL Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>PRU_ICSS_LRST</name>
                  <description>bit: 1 (RW)PER domain PRU-ICSS local reset control [0x0 = CLEAR; 0x1 = ASSERT]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>PER_PWRSTST</name>
              <addressOffset>0x08</addressOffset>
              <description>PER_PWRSTST Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>PowerStateSt</name>
                  <description>bit: 0,1 (R)Current Power State Status [see e_PWRSTST_MPU]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>LogicStateSt</name>
                  <description>bit: 2 (R)Logic state status [0x0 = logic in domain OFF; 0x1 = logic in domain ON]</description>
                  <bitOffset>2</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>PER_mem_statest</name>
                  <description>bit: 17,18 (R)PER domain memory state status [see e_PWRSTST_MPU]</description>
                  <bitOffset>3</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>InTransition</name>
                  <description>bit: 20 (R)Domain transition status [0x0 = No on-going transition on power domain; 0x1 = Power domain transition is in progress]</description>
                  <bitOffset>5</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ram_mem_statest</name>
                  <description>bit: 21,22 (R)OCMC(on chip memmory controller) RAM memory state status [see e_PWRSTST_MPU]</description>
                  <bitOffset>6</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>pru_icss_mem_statest</name>
                  <description>bit: 23,24 (R)PRU-ICSS memory state status [see e_PWRSTST_MPU]</description>
                  <bitOffset>8</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>PER_PWRSTCTRL</name>
              <addressOffset>0x0C</addressOffset>
              <description>PER_PWRSTCTRL Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>PowerState</name>
                  <description>bit: 0,1 (RW) PER domain power state control [see e_PWRSTST_PER]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>LogicRETState</name>
                  <description>bit: 3 (RW) Logic state when power domain is RETENTION [0x0 = logic_off; 0x1 = logic_ret]</description>
                  <bitOffset>2</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>LowPowerStateChange</name>
                  <description>bit: 4 (RW) Power state change request when domain has already performed asleep transition [0x0 = Do not request; 0x1 = Req]</description>
                  <bitOffset>3</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>pru_icss_mem_ONState</name>
                  <description>bit: 5,6 (RW) PRU-ICSS memory ON state [0x0..0x2 = Reserved; 0x3 = Memory is ON]</description>
                  <bitOffset>4</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-only</access>
                </field>
                <field>
                  <name>pru_icss_mem_RETState</name>
                  <description>bit: 7 (RW) PRU-ICSS memory RET state [0x0 = off; 0x1 = ret]</description>
                  <bitOffset>6</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>PER_mem_ONState</name>
                  <description>bit: 25,26 (RW) Other memories in PER Domain ON state [0x0..0x2 = Reserved; 0x3 = Memory is ON]</description>
                  <bitOffset>7</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-only</access>
                </field>
                <field>
                  <name>ram_mem_RETState</name>
                  <description>bit: 27 (RW) OCMC(on chip memmory controller) RAM memory RET state [0x0 = off; 0x1 = ret]</description>
                  <bitOffset>9</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>PER_mem_RETState</name>
                  <description>bit: 29 (RW) Other memories in PER Domain RET state [0x0 = off; 0x1 = ret]</description>
                  <bitOffset>10</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ram_mem_ONState</name>
                  <description>bit: 30,31 (RW) OCMC(on chip memmory controller) RAM memory on state [see e_PWRSTST_PER]</description>
                  <bitOffset>11</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
          </registers>
        </peripheral>
        <peripheral>
          <name>PRM_RTC</name>
          <description>Power Reset Module - RTC</description>
          <baseAddress>0x44E01000</baseAddress>
          <groupName>Power Reset Modules</groupName>
          <registers>
            <register>
              <name>RTC_PWRSTCTRL</name>
              <addressOffset>0x00</addressOffset>
              <description>RTC_PWRSTCTRL Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>LogicRETState</name>
                  <description>bit: 2 (RW) Logic state when power domain is RETENTION [0x0 = logic_off; 0x1 = logic_on]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>LowPowerStateChange</name>
                  <description>bit: 4 (RW) Power state change request when domain has already performed a sleep transition. [0x0 = Do not request; 0x1 = Request a low power state change]</description>
                  <bitOffset>1</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>RTC_PWRSTST</name>
              <addressOffset>0x04</addressOffset>
              <description>RTC_PWRSTST Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>LogicStateSt</name>
                  <description>bit: 2 (R) Logic state status [0x0 = Logic in domain is OFF; 0x1 = Logic in domain is ON]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>InTransition</name>
                  <description>bit: 20 (R)Domain transition status [ 0x0 = No on-going transition; 0x1 = transition is in progress.]</description>
                  <bitOffset>1</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
          </registers>
        </peripheral>
        <peripheral>
          <name>PRM_WKUP</name>
          <description>Power Reset Module - Wakeup</description>
          <baseAddress>0x44E00D00</baseAddress>
          <groupName>Power Reset Modules</groupName>
          <registers>
            <register>
              <name>WKUP_RSTCTRL</name>
              <addressOffset>0x00</addressOffset>
              <description>WKUP_RSTCTRL Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>WKUP_M3_LRST</name>
                  <description>bit: 3 (RW)Assert Reset to WKUP_M3 [0x0 = CLEAR; 0x1 = ASSERT]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>WKUP_PWRSTCTRL</name>
              <addressOffset>0x04</addressOffset>
              <description>WKUP_PWRSTCTRL Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>LogicRETState</name>
                  <description>bit: 3 (RW) Logic state when power domain is RETENTION [0x0 = logic off; 0x1 = logic_ret]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>LowPowerStateChange</name>
                  <description>bit: 4 (RW) Power state change request when domain has already performed a sleep transition [0x0 = Do not request; 0x1 = Request a low power state change]</description>
                  <bitOffset>1</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>WKUP_PWRSTST</name>
              <addressOffset>0x08</addressOffset>
              <description>WKUP_PWRSTST Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>LogicStateSt</name>
                  <description>bit: 2 (RW) Logic state status [0x0 = Logic in domain is OFF; 0x1 = Logic in domain is ON]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>Debugss_mem_statest</name>
                  <description>bit: 17,18 (RW) WKUP domain memory state status [see e_WKUP_DOMAIN_MEM_STATE]</description>
                  <bitOffset>1</bitOffset>
                  <bitWidth>2</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>InTransition</name>
                  <description>bit: 20 (RW) Domain transition status [0x0 = No on-going transition; 0x1 = Power domain transition is in progress]</description>
                  <bitOffset>3</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
            <register>
              <name>WKUP_RSTST</name>
              <addressOffset>0x0C</addressOffset>
              <description>WKUP_RSTST Register</description>
              <size>32</size>
              <access>read-write</access>
              <resetValue>0x00000000</resetValue>
              <fields>
                <field>
                  <name>WKUP_M3_LRST</name>
                  <description>bit: 5 (RW) M3 Processor has been reset [0x0 = No reset; 0x1 = M3 Processor has been reset]</description>
                  <bitOffset>0</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>EMULATION_M3_RST</name>
                  <description>bit: 6 (RW) M3 Processor has been reset due to emulation reset source e.g.assert reset command initiated by the icepick module [0x0 = No reset; 0x1 = M3 Processor has been reset]</description>
                  <bitOffset>1</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
                <field>
                  <name>ICECRUSHER_M3_RST</name>
                  <description>bit: 7 (RW) M3 Processor has been reset due to M3 ICECRUSHER1 reset event [0x0 = No reset; 0x1 = M3 Processor has been reset]</description>
                  <bitOffset>2</bitOffset>
                  <bitWidth>1</bitWidth>
                  <access>read-write</access>
                </field>
              </fields>
            </register>
          </registers>
        </peripheral>
  </peripherals>
</device>
