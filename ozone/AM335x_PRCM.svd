              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DPLL_REGM4XEN</name>
              <description>bit: 11 (Retrun 0) Enable the REGM4XEN mode of the DPLL.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
