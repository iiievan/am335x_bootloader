              <name>DPLL_SSC_EN</name>
              <description>bit: 12 (RW) Enable or disable Spread Spectrum Clocking [0x0 = SSC disabled; 0x1 = SSC enabled]</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DPLL_SSC_ACK</name>
              <description>bit: 13 (R) Acknowledgement from the DPLL regarding start and stop of Spread Spectrum Clocking feature [0x0 = SSC turned off; 0x1 = SSC turned on]</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DPLL_SSC_DOWNSPREAD</name>
              <description>bit: 14 (RW) Control if only low frequency spread is required [0x0 = spread on both sides of the programmed frequency; 0x1 = spread only on the lower side of the programmed frequency]</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>DPLL_SSC_TYPE</name>
              <description>bit: 15 (RW) Select Triangular Spread Spectrum clocking. [0x0 = is selected; 0x1 = Reserved]</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
