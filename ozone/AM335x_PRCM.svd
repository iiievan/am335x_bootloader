          <fields>
            <field>
              <name>DPLL_EN</name>
              <description>DPLL control.[see e_MPU_DPLL_EN]</description>
              <bitOffset>0</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
