            <field>
              <name>HSDIVIDER_CLKOUT1_PWDN</name>
              <description>bit: 12 Automatic power down for HSDIVIDER M4 divider and henceCLKOUT1 output when the o/p clock is gated [0x0 = keep powered;0x1 = powerdown]</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>DIV_M5_DPLL_CORE</name>
          <addressOffset>0x84</addressOffset>
