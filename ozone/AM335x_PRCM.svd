          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>HSDIVIDER_CLKOUT2_DIV</name>
              <description>DPLL post-divider factor, M5, for internal clock generation.Divide values from 1 to 31. [0x0 = reserved]</description>
              <bitOffset>0</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HSDIVIDER_CLKOUT2_DIVCHACK</name>
              <description>bit: 5 (R)indicates that the change in divider HSDIVIDER_CLKOUT2_DIV value has taken effect.</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HSDIVIDER_CLKOUT2_GATE_CTRL</name>
              <description>bit: 8 (RW)Control gating of HSDIVIDER CLKOUT2 [0x0 = auto gated;0x1 = force enabled]</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>ST_HSDIVIDER_CLKOUT2</name>
              <description>bit: 9 (R)HSDIVIDER CLKOUT2 status [0x0 = gated;0x1 = enabled]</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HSDIVIDER_CLKOUT2_PWDN</name>
              <description>bit: 12 Automatic power down for HSDIVIDER M5 divider and henceCLKOUT2 output when the o/p clock is gated [0x0 = keep powered;0x1 = powerdown]</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
